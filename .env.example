# Configuración SMTP de Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=tu-correo@gmail.com
EMAIL_PASS=tu-contraseña-de-aplicación-de-16-letras

# Vercel Cron Secret (Clave para proteger la URL /api/cron)
# Vercel inyecta esto automáticamente, pero puedes definirlo a mano para pruebas
CRON_SECRET=mi-clave-secreta-para-el-cron
